// FluxWork™ — Engine Declarations
// OmniScript™ Engine Connection Specifications

@app FluxWork
@version 1.0.0

// ============================================================
// ENGINE DECLARATIONS
// ============================================================

// HabitGenome™ (NC-08)
engine HabitGenome {
  @docket "NC-08"
  @protocol BIDIRECTIONAL
  @routing NexusCore
  @context_enrichment ENABLED
  
  signal outbound {
    type: HabitGenomeInboundSignal,
    description: "fluxwork_domain_telemetry",
    frequency: REALTIME,
    priority: HIGH
  }
  
  signal inbound {
    type: HabitGenomeOutboundIntelligence,
    description: "habitgenome_intelligence_feed",
    frequency: REALTIME,
    priority: HIGH
  }
}
